# ============================================
# CONFIGURAÇÃO DO STOCKFLOW
# ============================================
# Copie este arquivo para .env e preencha os valores

# Banco de Dados PostgreSQL
# Para desenvolvimento local com Docker: postgres://postgres:postgres@localhost:5432/stockflow
# Para Supabase: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgres://postgres:postgres@localhost:5432/stockflow

# Servidor
PORT=4173
HOST=0.0.0.0

# ============================================
# SUPABASE (Opcional - apenas se usar Supabase)
# ============================================
# Obtenha em: https://supabase.com/dashboard

SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-chave-anonima-aqui

# ============================================
# SEGURANÇA (Render Deploy)
# ============================================
# Chave de acesso para proteger o app
APP_ACCESS_KEY=sua-chave-segura-aqui
